@model IEnumerable<Quyen15.Models.Appointment>

@{
    ViewData["Title"] = "Doctor Appointments";
}

<div class="container mt-4">
    <h2 class="mb-4">Doctor Appointment Schedule</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Patient</th>
                <th>Phone</th>
                <th>Date</th>
                <th>Time</th>
                <th>Status</th>
                <th>Medical Record</th>
                <th>Test Results</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Patient?.Name</td>
                    <td>@item.Patient?.Phone</td>
                    <td>@item.AppointmentDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.AppointmentTime.ToString(@"hh\:mm")</td>

                    <td>
                        @if (item.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                        else if (item.Status == "Completed")
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else if (item.Status == "Cancelled")
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@item.Status</span>
                        }
                    </td>

                    <td>
                        @if (item.MedicalRecord != null)
                        {
                            <a asp-controller="MedicalRecords"
                               asp-action="Details"
                               asp-route-id="@item.MedicalRecord.IdRecord"
                               class="btn btn-info btn-sm">
                                View Record
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No record</span>
                        }
                    </td>

                    <td>
                        @if (item.TestResults != null && item.TestResults.Any())
                        {
                            foreach (var test in item.TestResults)
                            {
                                <div class="mb-1">
                                    <a asp-controller="TestResults"
                                       asp-action="Details"
                                       asp-route-id="@test.IdTestResult"
                                       class="btn btn-outline-primary btn-sm">
                                        @test.TestType
                                    </a>
                                </div>
                            }
                        }
                        else
                        {
                            <span class="text-muted">No test result</span>
                        }
                    </td>

                    <td>
                        @if (item.Status != "Cancelled" && item.MedicalRecord == null)
                        {
                            <a asp-controller="MedicalRecords"
                               asp-action="Create"
                               asp-route-appointmentId="@item.IdAppointment"
                               class="btn btn-success btn-sm">
                                Examine
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No action</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>